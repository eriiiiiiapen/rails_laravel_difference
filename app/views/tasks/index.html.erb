<% content_for :title, "Tasks" %>

<h1>Tasks</h1>

<div id="tasks">
  <% @tasks.each do |task| %>
    <%= render task %>
    <p>
      <%= link_to "Show this task", task %>
    </p>
  <% end %>
</div>

<%= link_to "New task", new_task_path %>

<div data-controller="hello">
  <button data-action="click->hello#greet">クリック</button>
  <span data-hello-target="test"></span>
  <span data-hello-target="test2"></span>
</div>
